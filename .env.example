# =============================================================================
# Loop — environment template (12-factor)
# Copy to `.env` and fill in. NEVER commit `.env`.
# Each service reads only the variables it needs (see app/core/config.py & lib/env.ts).
# =============================================================================

# ---- Global ----
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=info                     # debug | info | warning | error
LOG_FORMAT=console                 # console (dev) | json (prod)

# ---- Backend API (FastAPI) ----
# The agent runs shell commands, so the API binds loopback by default. Only set
# 0.0.0.0 behind a network boundary — and then set API_TOKEN below.
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1                      # uvicorn workers; scale horizontally in k8s instead
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=loop-web
JWT_AUDIENCE=loop-api
# When set, every /api/v1 route requires `Authorization: Bearer <token>`
# (health stays open). Required if you expose the API beyond localhost.
API_TOKEN=
CORS_ORIGINS=http://localhost:3000 # comma-separated

# ---- Database (PostgreSQL) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full async DSN used by SQLAlchemy. In compose/k8s this is assembled from the parts above.
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# ---- Cache / broker (Redis) ----
REDIS_URL=redis://localhost:6379/0

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=       # e.g. http://otel-collector:4317 ; empty = disabled
OTEL_SERVICE_NAME=api
PROMETHEUS_ENABLED=true

# ---- LLM providers (at least one required for the agent loop to run) ----
# The loop tries the default provider first and cascades to the others on a
# retryable failure. Leave a key blank to disable that provider.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat         # or deepseek-reasoner (R1) — stronger, pricier
GEMINI_API_KEY=
GLM_API_KEY=
# Local, fully-offline model via Ollama (no API key). Set the base URL to enable.
#   brew install ollama && ollama serve && ollama pull llama3.2
OLLAMA_BASE_URL=                    # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_DEFAULT_PROVIDER=deepseek       # anthropic | deepseek | gemini | glm | ollama
# A retryable failure (timeout / 5xx / empty) is retried on the same provider this
# many times (with linear backoff) before cascading to the next one.
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5

# ---- Agent loop ----
# inline  = run the loop in the API process (zero extra infra; great for a laptop)
# worker  = enqueue to Redis; a separate worker process runs the loop (scales out)
EXECUTION_MODE=inline
# Cap concurrent inline runs (each holds a DB connection for its whole run); extras queue.
AGENT_MAX_CONCURRENT_RUNS=8

# ---- Agent tools & safety ----
# Each task works inside its own subdirectory under this root.
AGENT_WORKSPACES_ROOT=./workspaces
# Optional single-user/local mode: expose only Git repositories below this root
# to project-backed tasks. Clients send a relative path; the absolute host path is
# never returned by the API. Leave empty on shared or remote deployments.
LOOP_LOCAL_PROJECTS_ROOT=           # e.g. /Users/me/projects
LOOP_CHANGESET_PREVIEW_BYTES=200000
# auto   = run allowlisted/unknown commands, hard-block dangerous ones
# manual = additionally refuse non-allowlisted commands until approved
AGENT_APPROVAL_MODE=auto
AGENT_COMMAND_TIMEOUT_SECONDS=60
# Mask secret-shaped strings (API keys, PEM keys, tokens) in tool output before it
# reaches the model, the ledger, or the API. On by default.
AGENT_REDACT_SECRETS=true
# Cross-task memory store (MEMORY.md + topics/).
AGENT_MEMORY_ROOT=./agent_memory
# Signed skills: a folder of skill bundles, and the ed25519 trust public key
# (PEM) their signatures must verify against. Empty = no skill is loadable.
AGENT_SKILLS_ROOT=./skills
# Trust root for skill signatures. Defaults to the committed dev key file so the
# bundled example skill (skills/hello-report) works out of the box. For real use,
# `make skill-keygen` and point this at your own trust_key.pem.
AGENT_SKILL_TRUST_PUBLIC_KEY=
AGENT_SKILL_TRUST_PUBLIC_KEY_FILE=./skills/trust_key.pem
# Optional: sign Receipts with an ed25519 key so they're tamper-PROOF (a forger
# without this key can't recompute a valid signature), not just tamper-evident.
# `make receipt-keygen` writes the key; unset = Receipts are hash-only (still
# cross-checked against the DB anchor + a re-hash of every output file).
AGENT_RECEIPT_SIGNING_KEY_FILE=
# Short-lived task authority issuer. Run make authority-keygen to write a private
# key for the Worker and a public verifier key for gateway/proxy services.
AGENT_AUTHORITY_SIGNING_KEY_FILE=./authority_signing_key.pem
AGENT_AUTHORITY_PUBLIC_KEY=
# Optional JSON kid-to-public-PEM map used to overlap old/new verifiers during rotation.
AGENT_AUTHORITY_PUBLIC_KEYS={}
AGENT_AUTHORITY_TOKEN_TTL_SECONDS=300
# Email (a task opts in with use_email). For Gmail use an app password.
# send_email always pauses for your approval; read_inbox content is treated as data.
SMTP_HOST=                          # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                          # your email address
SMTP_PASSWORD=                      # an app password, not your login password
SMTP_STARTTLS=true
IMAP_HOST=                          # e.g. imap.gmail.com
IMAP_PORT=993
EMAIL_FROM=                         # defaults to SMTP_USER

# Chat inlet (Telegram): set a bot token to let people send tasks from chat.
# ALWAYS set the allowlist for a bot that can run code / send email.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=          # comma-separated chat ids (required)
# With no allowlist the bot REFUSES to start (it can run code + send email).
# Only flip this on for a deliberately public bot.
TELEGRAM_ALLOW_PUBLIC=false

# Chat inlet (Slack Events API): point your Slack app's Event Subscriptions at
# POST /slack/events. Every request is signature-verified with the signing secret;
# the bot token posts replies. Set the channel allowlist since the bot runs code.
SLACK_BOT_TOKEN=                    # xoxb-... (chat:write scope)
SLACK_SIGNING_SECRET=               # from the app's Basic Information page
# With no allowlist the inlet REFUSES to act (it runs code) unless you opt into a
# public bot below — same fail-closed posture as Telegram.
SLACK_ALLOWED_CHANNELS=             # comma-separated channel ids
SLACK_ALLOW_PUBLIC=false

# Calendar over CalDAV (a task opts in with use_calendar). Works with iCloud /
# Fastmail / Nextcloud via an app password. create_event pauses for approval.
CALDAV_URL=                         # e.g. https://caldav.fastmail.com/dav/
CALDAV_USER=
CALDAV_PASSWORD=
CALDAV_CALENDAR=                    # optional: a calendar name; else the first

# Credential- and network-isolated protocol gateways. Each service receives only
# its own credentials and can reach only its signed upstream hosts through the proxy.
AGENT_EMAIL_GATEWAY_URL=
AGENT_CALENDAR_GATEWAY_URL=
AGENT_VISION_GATEWAY_URL=
AGENT_EMAIL_EGRESS_HOSTS=           # e.g. smtp.gmail.com,imap.gmail.com
AGENT_CALENDAR_EGRESS_HOSTS=        # hostname from CALDAV_URL
AGENT_VISION_EGRESS_HOSTS=generativelanguage.googleapis.com
PROVIDER_GATEWAY_GEMINI_API_KEY=
# The credentialless Browser Gateway has a separate internal URL and audience.
# Its deployment can connect only to the authenticated egress proxy.
AGENT_BROWSER_GATEWAY_URL=
AGENT_BROWSER_ENABLED=true
AGENT_BROWSER_COMMAND=npx -y @playwright/mcp@0.0.78 --headless --isolated
# Shell/browser/provider egress is only routed through this authenticated proxy. Tasks
# must declare explicit egress_hosts; an empty list is deny-all.
AGENT_EGRESS_PROXY_URL=
AGENT_EGRESS_PROXY_AUDIT_URL=
AGENT_REQUIRE_EGRESS_HOSTS=true
# Sandbox: run the agent's shell commands in an ephemeral Docker container.
# preferred = container when Docker + the image are available, else host (labeled);
# required = fail closed unless the selected sandbox backend is available; off = host.
# Build the image once: docker build -f apps/api/sandbox.Dockerfile -t loop-sandbox:latest apps/api
AGENT_SANDBOX=preferred
AGENT_SANDBOX_IMAGE=loop-sandbox:latest
AGENT_SANDBOX_IMAGE_DIGEST=          # required in production: sha256:<64 hex chars>

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_APP_NAME=Loop
API_INTERNAL_URL=http://localhost:8000
APP_BASE_URL=http://localhost:3000
WEB_AUTH_REQUIRED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must equal the API's SECRET_KEY so it can verify short-lived web sessions.
LOOP_SESSION_SECRET=change-me-in-production-use-openssl-rand-hex-32
