# =============================================================================
# Scalable Starter — environment template (12-factor)
# Copy to `.env` and fill in. NEVER commit `.env`.
# Each service reads only the variables it needs (see app/core/config.py & lib/env.ts).
# =============================================================================

# ---- Global ----
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=info                     # debug | info | warning | error
LOG_FORMAT=console                 # console (dev) | json (prod)

# ---- Backend API (FastAPI) ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                      # uvicorn workers; scale horizontally in k8s instead
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000 # comma-separated

# ---- Database (PostgreSQL) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full async DSN used by SQLAlchemy. In compose/k8s this is assembled from the parts above.
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# ---- Cache / broker (Redis) ----
REDIS_URL=redis://localhost:6379/0

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=       # e.g. http://otel-collector:4317 ; empty = disabled
OTEL_SERVICE_NAME=api
PROMETHEUS_ENABLED=true

# ---- LLM providers (at least one required for the agent loop to run) ----
# The loop tries the default provider first and cascades to the others on a
# retryable failure. Leave a key blank to disable that provider.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=
LLM_DEFAULT_PROVIDER=deepseek       # anthropic | deepseek | gemini | glm

# ---- Agent loop ----
# inline  = run the loop in the API process (zero extra infra; great for a laptop)
# worker  = enqueue to Redis; a separate worker process runs the loop (scales out)
EXECUTION_MODE=inline

# ---- Agent tools & safety ----
# Each task works inside its own subdirectory under this root.
AGENT_WORKSPACES_ROOT=./workspaces
# auto   = run allowlisted/unknown commands, hard-block dangerous ones
# manual = additionally refuse non-allowlisted commands until approved
AGENT_APPROVAL_MODE=auto
AGENT_COMMAND_TIMEOUT_SECONDS=60
# Cross-task memory store (MEMORY.md + topics/).
AGENT_MEMORY_ROOT=./agent_memory
# Signed skills: a folder of skill bundles, and the ed25519 trust public key
# (PEM) their signatures must verify against. Empty = no skill is loadable.
AGENT_SKILLS_ROOT=./skills
AGENT_SKILL_TRUST_PUBLIC_KEY=
# Headless browser via MCP (a task opts in with use_browser; needs Node/npx).
AGENT_BROWSER_ENABLED=true
AGENT_BROWSER_COMMAND=npx -y @playwright/mcp@latest --headless --isolated

# ---- Frontend (Next.js) ----
# Public vars are exposed to the browser — keep secrets out of NEXT_PUBLIC_*.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Loop
# Server-only var (used by Next.js server components / route handlers)
API_INTERNAL_URL=http://localhost:8000
