{
  "name": "loop",
  "version": "0.1.0",
  "private": true,
  "description": "Loop \u2014 a verifiable, least-authority autonomous agent runtime. Next.js + FastAPI, deployable on Kubernetes.",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3"
  }
}
