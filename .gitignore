# ---------- Agent skills (dev bundles) + signing keys ----------
# Ignore runtime skill dirs and all *.pem (private signing keys), but keep the
# committed example skill and its PUBLIC trust key so signed skills work OOTB.
apps/api/skills/*
!apps/api/skills/hello-report/
*.pem
!apps/api/skills/trust_key.pem

